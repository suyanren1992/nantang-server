# ══ 南塘云村 · 环境变量配置 ══
# 复制此文件为 .env，填入实际值后启动服务端。

# JWT 密钥（必填，生产环境用随机字符串）
JWT_SECRET=change-me-to-a-random-string-32chars

# ══ OP Chain 链上配置 ══
# RPC 端点（Alchemy / Infura / 公共节点）
OP_RPC_URL=https://mainnet.optimism.io

# NT 自定义代币合约地址
NT_TOKEN_CONTRACT=0x7563cb33148cD2b929ed85e69F697be13b515Bd0

# 共创营官方多签钱包（平台收款地址）
PLATFORM_WALLET_ADDRESS=0xf0aa2d24300de38c0d88f4f4d207e74b1a9d1a0d

# 扫描间隔（秒），默认 30
SCAN_INTERVAL=30

# 首次启动从当前块往回扫多少块（防漏），默认 500
SCAN_START_BLOCKS_BACK=500

# ══ 前端域名（CORS）══
FRONTEND_ORIGIN=http://localhost:8000

# ══ 已知钱包（文档参考，非运行时配置）══
# 共创营共建者钱包: 0xEB558CFa7CF4e1a8E1b79d7446f21C41A34c86Ac
# 砚仁个人钱包:     0x4640e76cfB16F769D7d08F883c32924060B51c2C
